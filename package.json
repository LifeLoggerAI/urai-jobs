{
  "name": "urai-jobs",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm:emulators\" \"npm:dev --workspace=web\"",
    "build": "npm run build --workspace=web && npm run build --workspace=functions",
    "build:functions": "npm run build --workspace=functions",
    "emulators": "firebase emulators:start --import=./firebase-data --export-on-exit",
    "seed": "npm run seed --workspace=scripts"
  },
  "devDependencies": {
    "@faker-js/faker": "^8.4.1",
    "@types/node": "^20.11.24",
    "concurrently": "^8.2.2",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3"
  },
  "workspaces": [
    "functions",
    "web",
    "packages/*",
    "scripts"
  ]
}
