{
  "name": "urai-jobs",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "concurrently \"npm run emulators\" \"npm run dev --prefix web\"",
    "build": "npm run build --prefix functions && npm run build --prefix web",
    "emulators": "firebase emulators:start --import=./firebase-data --export-on-exit",
    "deploy:hosting": "firebase deploy --only hosting",
    "deploy:functions": "firebase deploy --only functions",
    "deploy": "firebase deploy",
    "seed": "npm run seed --prefix functions"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
