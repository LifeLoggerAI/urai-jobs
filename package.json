{
  "name": "urai-jobs",
  "private": true,
  "packageManager": "pnpm@8.15.9",
  "workspaces": [
    "functions",
    "packages/shared-types",
    "web",
    "workers/*"
  ],
  "scripts": {
    "urai-jobs:verify": "node scripts/urai-jobs-verify.mjs && node scripts/activation-readiness-verify.mjs && node scripts/career-surfaces-verify.mjs && node scripts/career-runtime-smoke.mjs",
    "activation:verify": "node scripts/activation-readiness-verify.mjs && node scripts/career-surfaces-verify.mjs",
    "career:verify": "node scripts/career-surfaces-verify.mjs && node scripts/career-runtime-smoke.mjs",
    "career:smoke": "node scripts/career-runtime-smoke.mjs",
    "career:prod-smoke": "node scripts/prod-career-smoke.mjs",
    "career:evidence:validate": "node scripts/validate-career-smoke-evidence.mjs",
    "career:evidence:report": "node scripts/render-career-smoke-report.mjs",
    "career:release-evidence": "node scripts/career-release-evidence.mjs",
    "career-worker:build": "npm run build --prefix workers/career-worker",
    "career-worker:typecheck": "npm run typecheck --prefix workers/career-worker",
    "urai-jobs:smoke": "node scripts/urai-jobs-smoke.mjs",
    "test:smoke:local": "npm run urai-jobs:smoke",
    "smoke:local": "npm run urai-jobs:smoke",
    "urai-jobs:e2e": "node scripts/urai-jobs-e2e.mjs",
    "postinstall": "npm run build --prefix packages/shared-types",
    "lint": "npm run lint --prefix packages/shared-types --if-present && npm run lint --prefix functions --if-present && npm run lint --prefix web --if-present && npm run lint --prefix workers --if-present",
    "build": "npm run build --prefix packages/shared-types && npm run build --prefix functions && npm run build --prefix web --if-present && pnpm --dir workers install --frozen-lockfile=false && npm run build --prefix workers --if-present && npm run career-worker:build",
    "typecheck": "npm run typecheck --prefix packages/shared-types --if-present && npm run typecheck --prefix functions && npm run typecheck --prefix web --if-present && pnpm --dir workers install --frozen-lockfile=false && npm run typecheck --prefix workers --if-present && npm run career-worker:typecheck",
    "test": "npm run urai-jobs:verify && npm run urai-jobs:smoke && npm run build && npm run urai-jobs:deploy-precheck && npm run typecheck --prefix functions",
    "audit:systems": "node scripts/system-of-systems-audit.mjs",
    "deploy:dev": "firebase use dev && firebase deploy",
    "deploy:staging": "firebase use staging && firebase deploy",
    "deploy:prod": "firebase use prod && firebase deploy",
    "deploy:workers": "bash scripts/deploy-workers.sh",
    "deploy:firebase:prod": "bash scripts/deploy-firebase.sh prod",
    "deploy:managed-worker": "bash scripts/deploy-managed-worker.sh",
    "deploy:managed-worker:bootstrap": "bash scripts/bootstrap-managed-worker-iam.sh",
    "deploy:iam:bootstrap": "bash scripts/bootstrap-gcp-deploy-iam.sh",
    "deploy:canary": "bash scripts/canary-rollout.sh",
    "prod:precheck": "node scripts/prod-env-precheck.mjs",
    "prod:smoke": "node scripts/prod-smoke.mjs",
    "prod:career-smoke": "node scripts/prod-career-smoke.mjs",
    "prod:career-evidence:validate": "node scripts/validate-career-smoke-evidence.mjs",
    "prod:career-evidence:report": "node scripts/render-career-smoke-report.mjs",
    "prod:career-release-evidence": "node scripts/career-release-evidence.mjs",
    "prod:smoke-token": "node scripts/prod-smoke-token.mjs",
    "prod:verify-workers": "node scripts/verify-worker-health.mjs",
    "prod:stamp": "node scripts/stamp-deployment-artifact.mjs",
    "prod:rollback-worker": "bash scripts/rollback-cloud-run-workers.sh",
    "prod:apply-alerts": "bash scripts/apply-monitoring-alerts.sh",
    "prod:dashboard": "node scripts/generate-slo-dashboard.mjs",
    "prod:heartbeat": "node scripts/worker-heartbeat.mjs",
    "prod:drain-queue": "node scripts/admin-process-queue-now.mjs",
    "dlq:replay": "node scripts/replay-dlq-job.mjs",
    "dlq:cleanup": "node scripts/dlq-retention-cleanup.mjs",
    "worker:precheck": "node scripts/managed-worker-precheck.mjs",
    "worker:run": "node scripts/run-worker.mjs",
    "domains:verify": "node scripts/verify-custom-domains.mjs",
    "job:queue": "node scripts/queue-job.mjs",
    "leases:reclaim": "node scripts/reclaim-stale-leases.mjs",
    "dead:requeue": "node scripts/requeue-dead.mjs",
    "urai-jobs:deploy-precheck": "node scripts/urai-jobs-deploy-precheck.mjs",
    "dev": "npm run dev --prefix web",
    "dev:all": "npm run dev --prefix web",
    "check:workspace": "npm ls --depth=0 --workspaces --include-workspace-root"
  },
  "devDependencies": {
    "@types/uuid": "^10.0.0",
    "@urai-jobs/shared-types": "workspace:^",
    "firebase-admin": "^12.1.0",
    "ulid": "^2.3.0"
  },
  "dependencies": {
    "axios": "^1.15.0"
  }
}
