rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Path for resumes: resumes/{applicantId}/{applicationId}/{filename}
    match /resumes/{applicantId}/{applicationId}/{filename} {
      // 1. Admins with verified email can read any resume.
      allow read: if request.auth != null && request.auth.token.email_verified
                    && exists(/databases/(default)/documents/admins/$(request.auth.uid));

      // 2. An applicant can write ONLY if they have a valid token (e.g., from a callable function).
      //    This token-based approach is more secure for unauthenticated uploads.
      //    The token would be stored temporarily in Firestore and checked here.
      //    For simplicity in this audit, we will require the user to be signed in to upload.
      //    A full implementation would use a callable to vend a one-time-use upload token.
      allow write: if request.auth != null
                     && request.auth.uid == applicantId // User can only write to their own folder
                     && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                     && request.resource.contentType.matches('application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    // Deny all other access to storage.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
