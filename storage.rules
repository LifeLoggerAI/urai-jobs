rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check for admin privileges based on Firestore `admins` collection
    function isAdmin() {
      return exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Resumes are stored at resumes/{applicantId}/{applicationId}/{filename}
    // This path is intentionally restrictive.
    match /resumes/{applicantId}/{applicationId}/{filename} {

      // READ: Only admins can read resumes.
      allow read: if isAdmin();

      // WRITE: Only the applicant who owns the applicantId can upload.
      // We also enforce size and content type constraints.
      // This relies on the applicant being authenticated, which is the most secure approach.
      // The callable function `createResumeUpload` will enforce application-specific logic
      // before granting the client permission to attempt this upload.
      allow write: if request.auth != null && request.auth.uid == applicantId
                   && request.resource.size < 10 * 1024 * 1024 // 10MB limit
                   && request.resource.contentType.matches('application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    // Deny all other read/write operations on all other paths in storage by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
