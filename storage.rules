rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return signedIn()
        && firestore.get(/databases/(default)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isOwner(uid) {
      return signedIn() && request.auth.uid == uid;
    }

    // Job artifacts are written by backend workers/admin flows and readable only by
    // the owning user or an admin operator. Clients must not upload runtime output.
    match /jobs/{ownerUid}/{jobId}/{allPaths=**} {
      allow read: if isOwner(ownerUid) || isAdmin();
      allow write: if false;
    }

    // Export bundles are generated by backend processes and scoped to the owner.
    match /exports/{ownerUid}/{allPaths=**} {
      allow read: if isOwner(ownerUid) || isAdmin();
      allow write: if false;
    }

    // Operational evidence is admin-only and backend-written.
    match /evidence/{allPaths=**} {
      allow read: if isAdmin();
      allow write: if false;
    }

    // Temporary worker output is not client-accessible. Workers should use service
    // credentials or signed URLs outside of client Security Rules.
    match /tmp/{allPaths=**} {
      allow read, write: if false;
    }

    // Default-deny every other path.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
