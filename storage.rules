rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    function isOrgAdmin(orgId) {
      return request.auth != null && request.auth.token.orgId == orgId && request.auth.token.isAdmin == true;
    }

    match /resumes/{applicantId}/{applicationId}/{filename} {
      allow read: if isOrgAdmin(request.auth.token.orgId);
      allow write: if false;
    }

    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
