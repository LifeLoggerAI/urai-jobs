rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check for admin role
    function isAdmin() {
      return exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Resumes are private. Applicants upload to a specific path, admins can read.
    match /resumes/{applicantId}/{applicationId}/{filename} {
      // Admins can read any resume.
      allow read: if request.auth != null && isAdmin();

      // Allow write only if the request meets size and type constraints.
      // The actual authorization (e.g., via a token) will be handled by a callable function
      // which is more secure for unauthenticated or applicant-level access.
      // For now, we lock it down to admins, to be expanded with the callable function logic.
      allow write: if request.auth != null && isAdmin() &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    // Deny all other access to storage.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
