rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // --- Helper Functions ---
    function isSignedIn() {
      return request.auth != null;
    }

    // Note: We need a way to check admin status here. Since Storage Rules
    // cannot read from Firestore, the common pattern is to set a custom claim
    // on the user's auth token.
    function isOrgAdmin(orgId) {
      return isSignedIn() && request.auth.token.orgId == orgId && request.auth.token.isAdmin == true;
    }

    // --- Resume Upload Path ---
    // Path: /orgs/{orgId}/resumes/{applicantId}/{applicationId}/{filename}
    match /orgs/{orgId}/resumes/{applicantId}/{applicationId}/{filename} {

      // READ: Only an admin of the correct organization can read resumes.
      // This requires the `orgId` and `isAdmin` custom claims to be set.
      allow read: if isOrgAdmin(orgId);

      // WRITE: We do NOT allow direct writes from the client.
      // All uploads are handled via short-lived Signed URLs generated by the
      // `createResumeUpload` callable function. The function performs all
      // necessary validation (size, content type) before generating the URL.
      // This is more secure and flexible than trying to validate in rules.
      allow write: if false;

    }

    // --- Default Deny ---
    // Deny access to any other path in the bucket by default.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
