rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default deny
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Allow resume uploads only to a specific path, with a valid token
    // The token is generated by a callable function and stored in Firestore
    // This prevents unauthenticated users from uploading files
    match /orgs/{orgId}/resumes/{applicantId}/{applicationId}/{filename} {
      allow write: if request.auth != null &&
                    request.resource.size < 10 * 1024 * 1024 && // 10MB
                    request.resource.contentType.matches('application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document') &&
                    exists(/databases/(default)/documents/orgs/$(orgId)/applications/$(applicationId));
      allow read: if request.auth != null &&
                   (exists(/databases/(default)/documents/orgs/$(orgId)/admins/$(request.auth.uid)) || request.auth.uid == applicantId);
    }
  }
}