rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function userDoc() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function userPerms() {
      return signedIn() && userDoc().data.permissions is list
        ? userDoc().data.permissions
        : [];
    }

    function hasPerm(p) {
      return signedIn() && p in userPerms();
    }

    function sameTenant(resourceTenantId) {
      return signedIn() && userDoc().data.tenantId == resourceTenantId;
    }

    match /users/{uid} {
      allow read: if signedIn() && request.auth.uid == uid;
      allow write: if signedIn() && request.auth.uid == uid;
    }

    match /jobs/{jobId} {
      allow read: if hasPerm('jobs.read.any') || (hasPerm('jobs.read.own') && sameTenant(resource.data.tenantId) && resource.data.ownerUid == request.auth.uid);
      allow write: if false;
    }

    match /jobResults/{jobId} {
      allow read: if hasPerm('jobs.read.any') || hasPerm('jobs.read.own');
      allow write: if false;
    }

    match /logs/{logId} {
      allow read: if hasPerm('jobs.read.any');
      allow write: if false;
    }

    match /roles/{roleId} {
      allow read: if hasPerm('admin.roles.read');
      allow write: if false;
    }

    match /permissions/{permId} {
      allow read: if hasPerm('admin.roles.read');
      allow write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
