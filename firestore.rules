rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthenticated() {
      return request.auth != null;
    }

    function isOrgAdmin(orgId) {
      return request.auth.token.orgId == orgId && request.auth.token.role == "admin";
    }

    function isOrgMember(orgId) {
      return request.auth.token.orgId == orgId && (request.auth.token.role == "admin" || request.auth.token.role == "reviewer");
    }

    match /jobs/{jobId} {
      allow get: if true;
      allow list: if true;
      allow create, update, delete: if isOrgAdmin(request.resource.data.orgId);
    }

    match /jobPublic/{jobId} {
      allow get: if true;
      allow list: if true;
      allow write: if false;
    }

    match /applicants/{applicantId} {
      allow create: if true;
      allow read, update: if isOrgMember(request.resource.data.orgId);
      allow delete: if isOrgAdmin(request.resource.data.orgId);
    }

    match /applications/{applicationId} {
      allow create: if true;
      allow read, update: if isOrgMember(request.resource.data.orgId);
      allow delete: if isOrgAdmin(request.resource.data.orgId);
    }

    match /referrals/{refCode} {
      allow get: if true;
      allow create: if isOrgMember(request.resource.data.orgId);
      allow update: if isOrgAdmin(request.resource.data.orgId);
      allow delete: if isOrgAdmin(request.resource.data.orgId);
    }

    match /waitlist/{id} {
      allow create: if true;
      allow read, delete: if isOrgAdmin(request.resource.data.orgId);
    }

    match /admins/{uid} {
      allow read, write: if isOrgAdmin(request.resource.data.orgId);
    }

    match /events/{eventId} {
      allow create: if true;
      allow read: if isOrgMember(request.resource.data.orgId);
      allow write: if isOrgAdmin(request.resource.data.orgId);
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
