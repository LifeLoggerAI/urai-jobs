rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Lock down all access by default
    match /{document=**} {
      allow read, write: if false;
    }

    // Allow authenticated users to read and create jobs
    match /jobs/{jobId} {
      allow read, create: if request.auth != null;
      allow update: if request.auth.token.serviceAccount == true;
    }

    // Allow only service accounts to write to jobResults
    match /jobResults/{jobId} {
      allow read, write: if request.auth.token.serviceAccount == true;
    }
  }
}
