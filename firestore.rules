rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function signedIn() {
      return request.auth != null;
    }

    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }

    function isAdmin() {
      return signedIn() && getUserRole() == 'admin';
    }

    function isOwner(resource) {
      return signedIn() && request.auth.uid == resource.data.ownerUid;
    }

    function userProfileFieldsUnchanged() {
      return request.resource.data.role == resource.data.role
        && request.resource.data.orgId == resource.data.orgId
        && request.resource.data.permissions == resource.data.permissions
        && request.resource.data.disabled == resource.data.disabled;
    }

    match /users/{uid} {
      allow read: if signedIn() && (request.auth.uid == uid || isAdmin());
      allow create: if false;
      allow update: if signedIn()
        && request.auth.uid == uid
        && userProfileFieldsUnchanged();
      allow delete: if false;
    }

    match /jobs/{jobId} {
      allow read: if isOwner(resource) || isAdmin();
      allow write: if false;

      match /logs/{logId} {
        allow read: if isOwner(get(/databases/$(database)/documents/jobs/$(jobId))) || isAdmin();
        allow write: if false;
      }
    }

    match /jobQueue/{jobId} {
      allow read, write: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
