rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // --- Helper Functions ---
    // Is the user signed in?
    function isSignedIn() {
      return request.auth != null;
    }

    // Get the user's role from their custom claims.
    function getRole(orgId) {
      return request.auth.token.roles[orgId];
    }

    // Does the user have the 'admin' role for this org?
    function isOrgAdmin(orgId) {
      return isSignedIn() && getRole(orgId) == 'admin';
    }
    
    // Does the user have the 'member' role for this org?
    function isOrgMember(orgId) {
        return isSignedIn() && (getRole(orgId) == 'admin' || getRole(orgId) == 'member');
    }

    // --- Default Deny ---
    match /{path=**} {
      allow read, write: if false;
    }

    // --- Org Collections ---
    match /orgs/{orgId} {
      allow read: if isOrgMember(orgId);
      allow create: if isSignedIn(); // Org creation logic handled in a callable function
      allow update, delete: if isOrgAdmin(orgId);
    }

    // --- Sub-collections ---

    match /orgs/{orgId}/jobs/{jobId} {
      allow read: if isOrgMember(orgId);
      allow create, update: if isOrgAdmin(orgId);
      allow delete: if isOrgAdmin(orgId);
    }
    
    match /orgs/{orgId}/jobPublic/{jobId} {
        allow get: if true;
        allow list, create, update, delete: if false; // Managed by backend
    }

    match /orgs/{orgId}/applicants/{applicantId} {
      allow read: if isOrgMember(orgId);
      allow create, update, delete: if false; // Managed by backend
    }

    match /orgs/{orgId}/applications/{applicationId} {
      allow read: if isOrgMember(orgId);
      allow create: if isSignedIn(); // Public can create applications
      allow update: if isOrgAdmin(orgId);
      allow delete: if isOrgAdmin(orgId);
    }
    
    match /orgs/{orgId}/waitlist/{waitlistId} {
        allow create: if true;
        allow read, list, update, delete: if isOrgAdmin(orgId);
    }
    
    match /orgs/{orgId}/events/{eventId} {
        allow create: if true; // Public can create events
        allow read, list, update, delete: if isOrgAdmin(orgId);
    }
    
    match /orgs/{orgId}/referrals/{refCode} {
        allow read, list, create, update, delete: if isOrgAdmin(orgId);
    }
    
    match /orgs/{orgId}/admins/{uid} {
        allow read, list, create, update, delete: if isOrgAdmin(orgId);
    }
  }
}