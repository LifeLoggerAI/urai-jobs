rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAllowed(role) {
      return request.auth.token.role == role;
    }

    function isServiceAdmin() {
      return request.auth.token.serviceAccount == true;
    }

    match /jobs/{jobId} {
      allow get: if isServiceAdmin();
      allow list: if isServiceAdmin();
      allow create: if hasAll(['type', 'payload', 'status', 'priority', 'createdAt', 'retryCount', 'maxRetries', 'sourceService']) && request.resource.data.status == 'queued' && request.resource.data.type in ['data_enrichment', 'ai_analysis', 'asset_generation', 'analytics_aggregation'] && request.resource.data.priority is number && request.resource.data.priority > 0 && request.resource.data.retryCount == 0 && request.resource.data.maxRetries is number && request.resource.data.createdAt == request.time;
      allow update: if isServiceAdmin();
      allow delete: if false;

      function hasAll(keys) {
        return request.resource.data.keys().hasAll(keys);
      }
    }

    match /jobQueues/{queueName} {
      allow read, write: if isServiceAdmin();
    }

    match /jobResults/{resultId} {
      allow get: if isServiceAdmin();
      allow create: if request.resource.data.jobId is string && request.resource.data.completedAt == request.time;
      allow update, delete, list: if false;
    }

    match /jobLogs/{logId} {
      allow list, get: if isServiceAdmin();
      allow create: if request.resource.data.jobId is string && request.resource.data.timestamp == request.time;
      allow update, delete: if false;
    }

    match /{path=**} {
      allow read, write: if false;
    }
  }
}