rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isAuthenticated() {
      return request.auth != null;
    }

    function isUser(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function isEmployer() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'employer';
    }

    function isCandidate() {
      return isAuthenticated() && get(/databases/$(database)/documents/users/$(request.auth.uid)).data.userType == 'candidate';
    }

    match /{document=**} {
      allow read, write: if false;
    }

    match /users/{userId} {
      allow read, write: if isUser(userId);
    }

    match /candidateProfiles/{userId} {
      allow read, write: if isUser(userId) && isCandidate();
    }

    match /employerProfiles/{userId} {
      allow read, write: if isUser(userId) && isEmployer();
    }

    match /jobs/{jobId} {
      allow read;
      allow create: if isEmployer();
      allow update, delete: if isEmployer() && resource.data.employerId == request.auth.uid;

      match /applications/{applicationId} {
        allow create: if isCandidate();
        allow read: if (isEmployer() && get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid) || (isCandidate() && resource.data.applicantId == request.auth.uid);
        allow update: if isEmployer() && get(/databases/$(database)/documents/jobs/$(jobId)).data.employerId == request.auth.uid;
        allow delete: if isCandidate() && resource.data.applicantId == request.auth.uid;
      }
    }

    match /messages/{messageId} {
      allow create: if isAuthenticated() && request.resource.data.from == request.auth.uid;
      allow read: if isAuthenticated() && (resource.data.from == request.auth.uid || resource.data.to == request.auth.uid);
    }

    match /notifications/{notificationId} {
      allow read, update: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }
  }
}
