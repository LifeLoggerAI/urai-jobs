rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Helper function to check for admin role
    function isAdmin() {
      return exists(/databases/(default)/documents/admins/$(request.auth.uid));
    }

    // Resumes are private. Applicants upload to a specific path, admins can read.
    match /resumes/{applicantId}/{applicationId}/{filename} {
      allow read: if request.auth != null && isAdmin();

      allow write: if request.auth != null && request.auth.uid == applicantId &&
                   request.resource.size < 10 * 1024 * 1024 &&
                   request.resource.contentType.matches('application/pdf|application/msword|application/vnd.openxmlformats-officedocument.wordprocessingml.document');
    }

    // Deny all other access to storage.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
