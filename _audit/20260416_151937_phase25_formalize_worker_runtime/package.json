{
  "name": "urai-jobs",
  "private": true,
  "workspaces": [
    "functions",
    "packages/shared-types",
    "web",
    "workers/*"
  ],
  "scripts": {
    "postinstall": "npm run build -w @urai-jobs/shared-types",
