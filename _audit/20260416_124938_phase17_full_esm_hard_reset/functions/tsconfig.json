{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "outDir": "lib/functions",
    "rootDir": "src",
    "strict": false,
    "skipLibCheck": true,
    "esModuleInterop": false,
    "resolveJsonModule": true
  },
  "include": ["src/**/*"]
}
