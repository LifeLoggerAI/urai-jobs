# URAI Jobs Runtime production environment template
# Copy this to your deployment environment, secret manager, or GitHub Actions secrets.

URAI_ENV=prod
NODE_ENV=production
API_ALLOWED_ORIGINS=https://urai.app,https://admin.urai.app,https://analytics.urai.app

# Firebase / GCP
FIREBASE_PROJECT_ID=
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
GCP_REGION=us-central1
FIREBASE_HOSTING_SITE=urai-jobs

# Required secrets
WEBHOOK_SIGNING_SECRET=
MAILGUN_KEY=
MAILGUN_DOMAIN=

# Worker service names
NARRATOR_WORKER_SERVICE=narrator-worker
ASSET_WORKER_SERVICE=asset-worker
SPATIAL_WORKER_SERVICE=spatial-worker
STUDIO_WORKER_SERVICE=studio-worker

# Functions -> Cloud Run worker URLs
NARRATOR_WORKER_URL=
ASSET_WORKER_URL=
SPATIAL_WORKER_URL=
STUDIO_WORKER_URL=

# Worker runtime
GCS_BUCKET_NAME=
WORKER_SERVICE_ACCOUNT_EMAIL=

# Production smoke user/token inputs
# Prefer an admin/operator account with least privilege required for runtime smoke.
PROD_SMOKE_ID_TOKEN=
PROD_SMOKE_JOB_TYPE=narrator.tts
PROD_SMOKE_TEXT=URAI Jobs Runtime production smoke test
