# URAI Jobs Runtime production environment template
# Copy this to ops/production.env locally, or configure the same values in GitHub Actions, Firebase, Cloud Run, or Secret Manager.
# Do not commit real production secrets.

URAI_ENV=prod
NODE_ENV=production

# Public runtime origins allowed to call hosted APIs.
API_ALLOWED_ORIGINS=https://uraijobs.com,https://www.uraijobs.com,https://urai-jobs-563121397472.web.app,https://urai-jobs.web.app

# Firebase / GCP
FIREBASE_PROJECT_ID=urai-jobs
GCLOUD_PROJECT=urai-jobs
GOOGLE_CLOUD_PROJECT=urai-jobs
GCP_REGION=us-central1
FIREBASE_HOSTING_SITE=urai-jobs-563121397472

# Required production secret. Must be at least 24 characters and must not be a placeholder.
WEBHOOK_SIGNING_SECRET=

# Functions -> Cloud Run worker HTTPS URLs. These must be real https:// URLs.
NARRATOR_WORKER_URL=
ASSET_WORKER_URL=
SPATIAL_WORKER_URL=
STUDIO_WORKER_URL=

# Worker runtime artifact bucket.
GCS_BUCKET_NAME=

# Optional production integrations.
MAILGUN_KEY=
MAILGUN_DOMAIN=
WORKER_SERVICE_ACCOUNT_EMAIL=

# Optional production smoke user/token inputs.
# Prefer an admin/operator account with least privilege required for runtime smoke.
PROD_SMOKE_ID_TOKEN=
PROD_SMOKE_JOB_TYPE=narrator.tts
PROD_SMOKE_TEXT=URAI Jobs Runtime production smoke test
