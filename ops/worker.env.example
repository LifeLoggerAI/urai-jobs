# URAI Jobs managed worker environment template.
# Copy to a secure secret manager or deployment environment.
# Do not commit real secrets or real private service URLs unless they are intentionally public.

URAI_ENV=prod
FIREBASE_PROJECT_ID=urai-jobs
GCLOUD_PROJECT=urai-jobs
GOOGLE_CLOUD_PROJECT=urai-jobs
GCP_REGION=us-central1

# Cloud Run worker identity and behavior
WORKER_SERVICE_ACCOUNT_EMAIL=urai-jobs-worker@urai-jobs.iam.gserviceaccount.com
URAI_WORKER_SERVICE_NAME=urai-jobs-worker
URAI_WORKER_NAME=cloud-run-worker
URAI_JOB_TYPE=narrator.tts
URAI_WORKER_POLL_MS=2000
URAI_LEASE_MS=60000
URAI_MAX_ATTEMPTS=3
URAI_WORKER_MIN_INSTANCES=1
URAI_WORKER_MAX_INSTANCES=2
URAI_WORKER_CPU=1
URAI_WORKER_MEMORY=512Mi

# Production storage and external services
GCS_BUCKET_NAME=urai-jobs-artifacts
NARRATOR_WORKER_URL=https://narrator-worker.example.invalid
ASSET_WORKER_URL=https://asset-worker.example.invalid
SPATIAL_WORKER_URL=https://spatial-worker.example.invalid
STUDIO_WORKER_URL=https://studio-worker.example.invalid

# Security and API
API_ALLOWED_ORIGINS=https://uraijobs.com,https://www.uraijobs.com,https://urai-jobs.web.app
WEBHOOK_SIGNING_SECRET=replace-with-32-plus-character-secret

# Optional
MAILGUN_KEY=
MAILGUN_DOMAIN=
FIREBASE_HOSTING_SITE=urai-jobs
ARTIFACT_REPOSITORY=urai-jobs
