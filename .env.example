# URAI-Jobs example environment configuration
# Copy to `.env` and fill in real values for your environment.
# Do not commit secrets to source control.

# Deployment environment (e.g. dev, staging, prod)
URAI_ENV=dev

# Mail provider (optional)
MAILGUN_KEY=
MAILGUN_DOMAIN=

# Signing secret for verifying incoming webhooks
WEBHOOK_SIGNING_SECRET=

# Allowed origins for calling APIs (comma-separated)
API_ALLOWED_ORIGINS=http://localhost:3000

# Firebase / GCP project identifiers
FIREBASE_PROJECT_ID=
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
GCP_REGION=us-central1

# Firebase Hosting site id (optional if hosting the web frontend)
FIREBASE_HOSTING_SITE=

# Functions -> Cloud Run worker endpoints (must be https)
NARRATOR_WORKER_URL=
ASSET_WORKER_URL=
SPATIAL_WORKER_URL=
STUDIO_WORKER_URL=

# Worker runtime storage bucket
GCS_BUCKET_NAME=

# Service account used by Cloud Run workers (optional)
WORKER_SERVICE_ACCOUNT_EMAIL=

# Secret used for authenticating requests from functions to workers
WORKER_AUTH_SECRET=

# Local emulator defaults (only used during local development)
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FUNCTIONS_EMULATOR_ORIGIN=http://127.0.0.1:5001
