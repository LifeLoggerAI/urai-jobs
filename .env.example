MAILGUN_KEY=
MAILGUN_DOMAIN=
WEBHOOK_SIGNING_SECRET=
API_ALLOWED_ORIGINS=https://urai.app,https://admin.urai.app,https://analytics.urai.app
URAI_ENV=prod

# Firebase / GCP
FIREBASE_PROJECT_ID=
GCLOUD_PROJECT=
GOOGLE_CLOUD_PROJECT=
PUBSUB_JOB_EXECUTION_TOPIC=job-execution

# Functions -> Cloud Run workers
# Required in staging/prod for corresponding job families. Missing URLs fail jobs when URAI_ENV is staging/prod.
NARRATOR_WORKER_URL=
ASSET_WORKER_URL=
SPATIAL_WORKER_URL=
STUDIO_WORKER_URL=
CAREER_WORKER_URL=
CONTENT_WORKER_URL=
STORYTIME_WORKER_URL=
ANALYTICS_WORKER_URL=
COMMUNICATIONS_WORKER_URL=

# Worker auth / invocation
# Use Cloud Run IAM where possible. When using token auth, functions send this as Authorization: Bearer <token>.
URAI_JOBS_WORKER_TOKEN=
URAI_JOBS_WORKER_TIMEOUT_MS=120000
WORKER_SERVICE_ACCOUNT_EMAIL=

# Runtime safety limits
URAI_JOBS_MAX_PAYLOAD_BYTES=32768
URAI_JOBS_CREATE_RATE_LIMIT_PER_MINUTE=10
# Inline fallback is only for local/emulator smoke. It is ignored in staging/prod.
URAI_JOBS_ALLOW_INLINE_FALLBACK=false

# Worker runtime
GCS_BUCKET_NAME=
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_CLOUD_TTS_LOCATION=global

# Local emulator defaults
FIRESTORE_EMULATOR_HOST=127.0.0.1:8080
FIREBASE_AUTH_EMULATOR_HOST=127.0.0.1:9099
FUNCTIONS_EMULATOR_ORIGIN=http://127.0.0.1:5001
FUNCTIONS_EMULATOR=true
